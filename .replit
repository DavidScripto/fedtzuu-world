modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 3000

[env]
PORT = "5000"

[deployment]
deploymentTarget = "vm"
run = ["node", "dist/index.cjs"]
build = ["npm", "run", "build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "platform-tests"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "platform-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "TEST_BASE_URL=http://localhost:5000 npx tsx scripts/test-agent.ts"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "console"

[agent]
integrations = ["javascript_paypal:1.0.0", "github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
PORT = "5000"
CF_ACCOUNT_ID = "600ebc643b3017c3d093ce284d3f7c5b"
